# Votre clé API Anthropic (récupérable sur console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI

# Port du serveur (3001 par défaut)
PORT=3001

# Origines autorisées à appeler le proxy (séparées par des virgules)
# Mettez l'URL exacte de votre site en production
# Exemple : https://talent-bridge.fr,https://www.talent-bridge.fr
# En développement local, laissez vide pour tout autoriser
ALLOWED_ORIGINS=https://talent-bridge.fr,https://www.talent-bridge.fr
